<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    tools:layout_editor_absoluteX="182dp"
    tools:layout_editor_absoluteY="194dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="250dp"
                android:layout_height="140dp"
                android:layout_marginTop="33dp"
                android:layout_marginBottom="45dp"
                android:contentDescription="logo"
                app:layout_constraintBottom_toBottomOf="@+id/txtPastelChoclo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/logo" />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="90dp"
                android:layout_height="115dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="171dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="171dp"
                android:contentDescription="imgCazuela"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toTopOf="@+id/switchPropina"
                app:layout_constraintEnd_toEndOf="@+id/imageView4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/pastel" />

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginStart="14dp"
                android:layout_marginTop="108dp"
                android:layout_marginEnd="21dp"
                android:layout_marginBottom="108dp"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/txtSubtotalPastel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/txtPastelChoclo"
                app:srcCompat="@drawable/cazuela" />

            <TextView
                android:id="@+id/txtPastelChoclo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="21dp"
                android:layout_marginBottom="14dp"
                android:text="Pastel De Choclo"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/editPastelChoclo"
                app:layout_constraintEnd_toEndOf="@+id/imageView2" />

            <TextView
                android:id="@+id/txtCazuela"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:text="Cazuela"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/txtSubtotalPastel"
                app:layout_constraintTop_toBottomOf="@+id/txtSubtotalPastel" />

            <TextView
                android:id="@+id/txtCantidadPastelChoclo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="130dp"
                android:text="cantidad"
                app:layout_constraintEnd_toEndOf="@+id/txtPastelChoclo"
                app:layout_constraintTop_toTopOf="@+id/editPastelChoclo" />

            <TextView
                android:id="@+id/txtCantidadCazuela"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="21dp"
                android:text="Cantidad: "
                app:layout_constraintBaseline_toBaselineOf="@+id/editCazuela"
                app:layout_constraintStart_toEndOf="@+id/imageView4" />

            <TextView
                android:id="@+id/txtSubtotalPastel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="36000"
                app:layout_constraintBottom_toTopOf="@+id/imageView4"
                app:layout_constraintStart_toStartOf="@+id/txtCantidadPastelChoclo"
                app:layout_constraintTop_toTopOf="@+id/imageView4" />

            <TextView
                android:id="@+id/txtSubtotalCazuela"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="20dp"
                android:text="10000"
                app:layout_constraintBottom_toTopOf="@+id/txtTotal"
                app:layout_constraintEnd_toEndOf="@+id/txtCantidadCazuela" />

            <TextView
                android:id="@+id/txtTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="23dp"
                android:layout_marginBottom="11dp"
                android:text="Comida"
                app:layout_constraintBottom_toTopOf="@+id/switchPropina"
                app:layout_constraintEnd_toEndOf="@+id/switchPropina" />

            <TextView
                android:id="@+id/txtPrecioTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="$0"
                app:layout_constraintBottom_toTopOf="@+id/txtValorPropina"
                app:layout_constraintStart_toStartOf="@+id/txtValorPropina" />

            <TextView
                android:id="@+id/txtValorPropina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="$0"
                app:layout_constraintBottom_toTopOf="@+id/txtTotalCuenta"
                app:layout_constraintStart_toStartOf="@+id/txtTotalCuenta" />

            <TextView
                android:id="@+id/txtTotalPropina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="31dp"
                android:text="Total"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/switchPropina" />

            <TextView
                android:id="@+id/txtTotalCuenta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <Switch
                android:id="@+id/switchPropina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="23dp"
                android:text="Propina"
                app:layout_constraintBottom_toBottomOf="@+id/txtValorPropina"
                app:layout_constraintEnd_toStartOf="@+id/txtTotalCuenta"
                app:layout_constraintTop_toBottomOf="@+id/txtValorPropina"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <EditText
                android:id="@+id/editPastelChoclo"
                android:layout_width="119dp"
                android:layout_height="53dp"
                android:layout_marginStart="7dp"
                android:layout_marginEnd="6dp"
                android:ems="10"
                android:inputType="number"
                android:text="0"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/txtPastelChoclo"
                app:layout_constraintStart_toEndOf="@+id/txtCantidadPastelChoclo"
                app:layout_constraintTop_toTopOf="parent" />

            <EditText
                android:id="@+id/editCazuela"
                android:layout_width="114dp"
                android:layout_height="43dp"
                android:layout_marginStart="39dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="38dp"
                android:ems="10"
                android:inputType="number"
                android:text="0"
                app:layout_constraintBottom_toBottomOf="@+id/txtSubtotalCazuela"
                app:layout_constraintStart_toStartOf="@+id/txtCazuela"
                app:layout_constraintTop_toTopOf="@+id/txtCazuela" />


        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>